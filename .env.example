# ── Database ───────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://aeo:aeo_dev@localhost:5433/aeo_suite

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT (RS256 — generate with: openssl genrsa -out private.pem 2048) ──────────
# base64-encode keys: openssl base64 -in private.pem | tr -d '\n'
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
JWT_EXPIRES_IN=86400
REFRESH_TOKEN_EXPIRES_IN=2592000

# ── Encryption (AES-256 for API keys at rest) ──────────────────────────────────
# generate: openssl rand -hex 32
ENCRYPTION_KEY=

# ── AI Engine API Keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
PERPLEXITY_API_KEY=
XAI_API_KEY=

# ── Email ──────────────────────────────────────────────────────────────────────
SENDGRID_API_KEY=

# ── Billing ────────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ── Observability ──────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Server ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ALLOWED_ORIGINS=http://localhost:3001

# ── Cost Alerting ──────────────────────────────────────────────────────────────
# USD amount per tenant per day before alert fires
DAILY_COST_ALERT_THRESHOLD=10
